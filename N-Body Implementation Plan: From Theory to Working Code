### Core Physics Module
```python
# nbody_core.py

import numpy as np
from dataclasses import dataclass
from typing import List, Tuple

@dataclass
class Particle:
    position: np.ndarray  # 3D position
    velocity: np.ndarray  # 3D velocity
    mass: float
    id: int

class NBodyState:
    def __init__(self, particles: List[Particle]):
        self.particles = particles
        self.N = len(particles)
        self.time = 0.0
        
    def compute_acceleration(self, i: int, softening=0.01) -> np.ndarray:
        """Compute gravitational acceleration on particle i"""
        G = 1.0  # Use N-body units
        acc = np.zeros(3)
        pos_i = self.particles[i].position
        
        for j, p in enumerate(self.particles):
            if i == j:
                continue
            r_vec = p.position - pos_i
            r = np.linalg.norm(r_vec)
            r_soft = np.sqrt(r**2 + softening**2)
            acc += G * p.mass * r_vec / r_soft**3
            
        return acc
    
    def leapfrog_step(self, dt: float):
        """Simple leapfrog integrator"""
        # Kick
        for i, p in enumerate(self.particles):
            acc = self.compute_acceleration(i)
            p.velocity += 0.5 * dt * acc
        
        # Drift
        for p in self.particles:
            p.position += dt * p.velocity
        
        # Kick
        for i, p in enumerate(self.particles):
            acc = self.compute_acceleration(i)
            p.velocity += 0.5 * dt * acc
        
        self.time += dt
```

## Phase 2: O(N) Structural Monitor (1-2 days)

### Linear Complexity Metrics
```python
# structural_monitor.py

class StructuralMonitor:
    def __init__(self, threshold=0.1):
        self.threshold = threshold
        self.previous_state = None
        
    def compute_virial_ratio(self, state: NBodyState) -> float:
        """O(N) kinetic energy, O(N) potential via sampling"""
        # Kinetic: exact, O(N)
        kinetic = sum(0.5 * p.mass * np.dot(p.velocity, p.velocity) 
                      for p in state.particles)
        
        # Potential: sampled, O(N)
        potential = 0.0
        sample_size = max(10, int(np.sqrt(state.N)))
        
        for i, p in enumerate(state.particles):
            # Sample sqrt(N) neighbors
            neighbors = np.random.choice(
                [j for j in range(state.N) if j != i],
                size=min(sample_size, state.N - 1),
                replace=False
            )
            for j in neighbors:
                r = np.linalg.norm(p.position - state.particles[j].position)
                potential -= p.mass * state.particles[j].mass / r
        
        # Scale back to full estimate
        potential *= state.N / sample_size
        
        return 2 * kinetic / abs(potential) if potential != 0 else 1.0
    
    def compute_escape_fraction(self, state: NBodyState) -> float:
        """O(N) - fraction of particles near escape velocity"""
        # Rough escape velocity estimate
        total_mass = sum(p.mass for p in state.particles)
        avg_radius = np.mean([np.linalg.norm(p.position) for p in state.particles])
        v_escape = np.sqrt(2.0 * total_mass / avg_radius)
        
        count = sum(1 for p in state.particles 
                    if np.linalg.norm(p.velocity) > 0.8 * v_escape)
        return count / state.N
    
    def compute_binding_distribution(self, state: NBodyState) -> np.ndarray:
        """O(N) - binding energy to nearest massive neighbor"""
        binding = []
        for i, p in enumerate(state.particles):
            # Find nearest neighbor (O(N) per particle, but simple)
            min_potential = 0
            for j, p2 in enumerate(state.particles):
                if i == j:
                    continue
                r = np.linalg.norm(p.position - p2.position)
                potential = -p.mass * p2.mass / r
                if potential < min_potential:
                    min_potential = potential
            binding.append(min_potential)
        return np.array(binding)
    
    def compute_divergence(self, state: NBodyState) -> float:
        """Weighted combination of structural metrics - O(N)"""
        virial = self.compute_virial_ratio(state)
        escape_frac = self.compute_escape_fraction(state)
        binding_dist = self.compute_binding_distribution(state)
        
        if self.previous_state is None:
            self.previous_state = {
                'virial': virial,
                'escape': escape_frac,
                'binding': binding_dist
            }
            return 0.0
        
        # Compute changes
        virial_change = abs(virial - self.previous_state['virial'])
        escape_change = abs(escape_frac - self.previous_state['escape'])
        
        # Kolmogorov-Smirnov test on binding distribution
        from scipy.stats import ks_2samp
        ks_stat, _ = ks_2samp(binding_dist, self.previous_state['binding'])
        
        # Weighted divergence
        divergence = (
            0.3 * virial_change +
            0.3 * escape_change +
            0.4 * ks_stat
        )
        
        return divergence
    
    def check_threshold(self, state: NBodyState) -> bool:
        """Return True if structural phase transition detected"""
        phi = self.compute_divergence(state)
        return phi > self.threshold
```

## Phase 3: Five-Stage Integration Loop (1 day)

### Main Simulation Driver
```python
# five_stage_nbody.py

class FiveStageNBody:
    def __init__(self, initial_state: NBodyState, threshold=0.1):
        self.state = initial_state
        self.monitor = StructuralMonitor(threshold)
        self.reactivation_count = 0
        self.history = {
            'time': [],
            'divergence': [],
            'reactivations': []
        }
    
    def run(self, total_time: float, dt: float, check_interval=10):
        """Main simulation loop with threshold detection"""
        steps = int(total_time / dt)
        
        for step in range(steps):
            # Stage 1: Monitor (every check_interval steps)
            if step % check_interval == 0:
                divergence = self.monitor.compute_divergence(self.state)
                self.history['time'].append(self.state.time)
                self.history['divergence'].append(divergence)
                
                if self.monitor.check_threshold(self.state):
                    # Threshold crossed - trigger reactivation
                    self.reactivate()
                    self.history['reactivations'].append(self.state.time)
            
            # Regular integration step
            self.state.leapfrog_step(dt)
    
    def reactivate(self):
        """Stages 2-5: Structural reset"""
        self.reactivation_count += 1
        
        # Stage 2: Selective Destabilization
